rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - email: string (optional) - The user's email address.
    //   - phoneNumber: string (optional) - The user's mobile number.
    //   - displayName: string (optional) - The user's display name.
    //   - formData: map (required) - The complete financial questionnaire data.
    //   - currentStep: int (optional) - The last step the user was on.
    //   - updatedAt: timestamp (optional) - The last time the data was saved.
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             ((request.auth.token.email == "akadzitu@gmail.com" || request.auth.token.email == "acuityconsultingke@gmail.com") && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'formData']) &&
             data.uid is string &&
             data.formData is map &&
             (!('email' in data) || data.email == null || data.email is string) &&
             (!('phoneNumber' in data) || data.phoneNumber == null || data.phoneNumber is string) &&
             (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
             (!('currentStep' in data) || data.currentStep is int) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /recruits/{recruitId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /academy/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
